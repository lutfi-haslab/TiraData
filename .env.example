# ─── Storage ──────────────────────────────────────────────────────────────────
STORE=sqlite                  # sqlite | postgres
DB_PATH=tiradata.db           # SQLite only

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Retention (days) ────────────────────────────────────────────────────────
TTL_LOGS_DAYS=30
TTL_METRICS_DAYS=90
TTL_TRACES_DAYS=7

# ─── PostgreSQL (only needed when STORE=postgres) ─────────────────────────────
# DATABASE_URL=postgres://user:password@localhost:5432/tiradata
